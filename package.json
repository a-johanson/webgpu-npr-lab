{
    "name": "webgpu-npr-lab",
    "version": "0.1.0",
    "description": "Non-photorealistic rendering based on a hybrid WebGPU-CPU pipeline",
    "main": "public/js/main.js",
    "scripts": {
        "test": "rm -rf ./dist-test && npx esbuild \"./src/**/*.test.ts\" --bundle --platform=node --format=esm --target=es2024 --outdir=./dist-test --outbase=./src && node ./scripts/run-tests.mjs",
        "check": "npx tsc --noEmit && npx biome check .",
        "lint": "npx tsc --noEmit && npx biome check --write .",
        "install-hook": "sh ./scripts/install-hook.sh",
        "clean": "rm -rf ./public/js/*",
        "build": "npm run clean && npx esbuild ./src/main.ts --bundle --format=esm --minify --target=es2024 --entry-names=[name] --outdir=./public/js",
        "dev": "npx esbuild ./src/main.ts --bundle --sourcemap --format=esm --target=es2024 --entry-names=[name] --outdir=./public/js --servedir=./public"
    },
    "keywords": [
        "webgpu",
        "npr",
        "non-photorealistic rendering",
        "gpu",
        "cpu"
    ],
    "author": "Ane Johanson",
    "license": "MIT",
    "type": "module",
    "devDependencies": {
        "@biomejs/biome": "2.3.15",
        "@webgpu/types": "0.1.69",
        "esbuild": "0.27.3",
        "typescript": "5.9.3"
    }
}
